public static int primesBetween(int lower, int upper)
{
    int count = 0; // counting primes form 0

    // go through all the numbers
    for(int i = lower; i <= upper; i++)
    {
        // if prime add 1
        if(isPrime(i))
        {
            count = count + 1;
        }
    }

    return count; // done pls pls it works
}
