public static int primesBetween(int lower, int upper)
{
    int count = 0; // counting primes lol

    // go through all the numbers
    for(int i = lower; i <= upper; i++)
    {
        // if it's prime then add 1
        if(isPrime(i))
        {
            count = count + 1;
        }
    }

    return count; // done
}
